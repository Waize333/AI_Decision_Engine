# =============================================================
# AI Decision Engine — .gitignore
# =============================================================

# ─── SECRETS (CRITICAL — never commit these) ─────────────────
.env
.env.*
!.env.example        # exception: the template IS committed
*.pem
*.key
secrets/

# ─── PYTHON ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
pip-wheel-metadata/

# ─── VIRTUAL ENVIRONMENTS ────────────────────────────────────
venv/
.venv/
env/
ENV/
.env.local

# ─── TESTING & COVERAGE ──────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml

# ─── IDE / EDITOR ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── DOCKER ──────────────────────────────────────────────────
# Keep docker-compose files, but ignore local override
docker-compose.override.yml

# ─── DATABASE ────────────────────────────────────────────────
*.sqlite
*.db

# ─── MODEL FILES (large binaries) ────────────────────────────
# These go in a model registry (S3, MLflow), not Git
models/*.pkl
models/*.joblib
models/*.h5
models/*.pt
models/*.onnx

# ─── LOGS ────────────────────────────────────────────────────
logs/
*.log

# ─── MISC ────────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/
node_modules/
